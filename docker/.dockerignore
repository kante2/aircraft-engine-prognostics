# ============================================
# Git
# ============================================
.git
.gitignore
.gitattributes

# ============================================
# Data (대용량, 마운트로 처리)
# ============================================
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# ============================================
# Results (학습 산출물, 마운트로 처리)
# ============================================
results/checkpoints/*
results/logs/*
!results/checkpoints/.gitkeep

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# ============================================
# Virtual environments (Docker 안에서 안 씀)
# ============================================
venv/
.venv/
env/

# ============================================
# IDE
# ============================================
.vscode/
.idea/
*.swp

# ============================================
# OS
# ============================================
.DS_Store
Thumbs.db

# ============================================
# Docker 자기 자신
# ============================================
docker/